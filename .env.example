# ◊·κ FallCore environment · copy to .env and edit

# Public port the proxy listens on (Anthropic-API-compatible)
FALLCORE_PORT=11434

# Local model (matches what you `ollama pull`)
# Lite:       llama3.1:8b
# Pro:        qwen2.5:32b
# Sovereign:  qwen2.5:72b   (recommended for procurement / legal / finance work)
OLLAMA_MODEL=qwen2.5:32b

# Anthropic key for cascade fallthrough · OPTIONAL
# Leave blank to force local-only (503 on low-confidence queries)
ANTHROPIC_FALLBACK_KEY=

# How confident must the local model be to keep its answer?
# 0.6 = pragmatic default · push to 0.8 to force more frontier calls until you trust local
CONFIDENCE_THRESHOLD=0.6
